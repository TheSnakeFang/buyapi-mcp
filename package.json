  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/TheSnakeFang/buyapi-mcp"
  },
  "homepage": "https://buyapi.ai",
  "engines": {
    "node": ">=18"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.12.1",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.4",
    "@types/node": "^22.15.3",
    "eslint": "^9.39.4",
    "tsup": "^8.4.0",
    "typescript": "^5.8.3",
    "typescript-eslint": "^8.59.0",
    "vitest": "^4.1.4"
  }
