{
  "name": "buyapi",
  "mcpName": "io.github.TheSnakeFang/buyapi-mcp",
  "version": "0.7.1",
  "description": "BuyAPI CLI and MCP server — unbiased vendor intelligence for AI coding agents",
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "files": [
    "dist",
    "README.md",
    "CHANGELOG.md",
    "LICENSE"
  ],
  "bin": {
    "buyapi": "dist/index.js",
    "buyapi-mcp": "dist/index.js"
  },
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "start": "node dist/index.mjs",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit",
    "lint": "eslint src/",
    "prepublishOnly": "pnpm build"
  },
  "keywords": [
    "mcp",
    "mcp-server",
    "vendor",
    "stack",
    "developer-tools",
    "ai-agents",
    "vibe-coding",
    "vendor-intelligence"
  ],
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/TheSnakeFang/buyapi-mcp.git"
  },
  "homepage": "https://buyapi.ai",
  "engines": {
    "node": ">=18"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.12.1",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.4",
    "@types/node": "^25.6.0",
    "eslint": "^10.3.0",
    "tsup": "^8.4.0",
    "typescript": "^5.8.3",
    "typescript-eslint": "^8.59.2",
    "vitest": "^4.1.5"
  },
  "pnpm": {
    "overrides": {
      "hono": "4.12.16",
      "ip-address": "10.1.1"
    }
  }
}
