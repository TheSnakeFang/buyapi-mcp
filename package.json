{
  "name": "buyapi-mcp",
  "version": "0.2.0",
  "description": "BuyAPI MCP Server — unbiased vendor intelligence for AI coding agents",
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "bin": {
    "buyapi-mcp": "dist/index.js",
    "buyapi": "dist/index.js"
  },
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
